# Copy to .env and fill in values
PORT=5000
MONGODB_URI=mongodb://localhost:27017/chronohub
JWT_SECRET=your-super-secret-jwt-key

# REQUIRED for password reset and CORS - your frontend URL
CLIENT_URL=http://localhost:5173

# Optional: for Google Sign-In. Use the same Client ID as frontend (VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SMTP Settings for Contact Form (optional - messages will be logged if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=support@chronohub.com
